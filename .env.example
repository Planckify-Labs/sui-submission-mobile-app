# ─────────────────────────────────────────────────────────────────────
# TakumiPay mobile — environment variables
# ─────────────────────────────────────────────────────────────────────
#
# Per umkm-usdc-payout-spec §10, the payment-path surface is locked to
# THREE bootstrap/security values that can't be served from the API
# itself (chicken-and-egg) or from a backend row:
#
#   1. EXPO_PUBLIC_API_URL                    — backend base URL
#   2. EXPO_PUBLIC_TAKUMIPAY_QR_PUBKEY_JWK    — bundled QR verifier key
#   3. EXPO_PUBLIC_EIP7702_ALLOWLIST          — delegate allowlist (OTA)
#
# Every per-chain coordinate (RPC URLs, USDC token addresses, Gateway,
# Paymaster, x402 domain, bundler URLs) rides on the enriched
# `GET /v1/blockchains` endpoint (task 21) and is consumed through
# `useBlockchainsWithStorage()` + `buildChainConfigFromBlockchain`. DO
# NOT add a `EXPO_PUBLIC_<CHAIN>_*` variable — that breaks the
# zero-release chain-addition story. Thread it through a `blockchains`
# row instead.
#
# Peripheral feature vars (Google OAuth, AI agent, MPC) are kept below
# because they belong to orthogonal subsystems; they are not on the
# scan→pay critical path and have their own lifecycles.
#
# ── Payment-path essentials (spec §10) ───────────────────────────────

# API auth key for the TakumiPay backend. Paired with EXPO_PUBLIC_API_URL
# on every ky request. Public by `EXPO_PUBLIC_*` naming — treat as
# rate-limit/identification, not a secret. Backend must accept this key
# only from app-bound User-Agents and enforce per-device SIWE on top.
EXPO_PUBLIC_API_KEY=tk_mobile_app_api_key_12345678901234567890123456789012345

# TakumiPay API base URL — bootstrap coordinate. Can't fetch this from
# the API itself (chicken/egg); must be baked into the build.
EXPO_PUBLIC_API_URL=http://192.168.1.13:4000

# TakumiPay signed-QR public verifier key (ES256 P-256 JWK). Bundled so
# the merchant-QR detector (§4.4, task 09) can verify JWS payloads
# OFFLINE — we can't trust an API-delivered pubkey to verify a QR the
# user just scanned without a connection. Mobile builds FAIL FAST if
# missing (see constants/takumipayKey.ts).
#
# Single-line JSON:
#   {"kty":"EC","crv":"P-256","x":"…","y":"…","alg":"ES256","kid":"YYYY-MM-DD"}
#
# Rotation: push via `eas update --channel production` on the same
# channel as EXPO_PUBLIC_EIP7702_ALLOWLIST. Full procedure:
# docs/jwk_rotation_runbook.md.
EXPO_PUBLIC_TAKUMIPAY_QR_PUBKEY_JWK=

# EIP-7702 authorized-delegator allowlist — comma-separated hex
# addresses, lowercased, no whitespace. The zero address is always
# permitted (revoke path) and does not need to appear here.
#
# Format:
#   EXPO_PUBLIC_EIP7702_ALLOWLIST=0xabc…,0xdef…
#
# Consumed by `services/chains/evm/eip7702Guard.ts`. OTA-rotatable —
# push via `eas update --channel production` when a new delegator is
# governance-approved (see docs/eip7702-delegator-allowlist-spec.md).
# Must never contain a chain-specific RPC or contract coordinate;
# chain coordinates live in the `blockchains` row.
EXPO_PUBLIC_EIP7702_ALLOWLIST=

# ── Peripheral feature vars (orthogonal subsystems) ──────────────────

NODE_ENV=production

# AI agent API (Takumi Agent API, §8). Separate host from the payments
# backend so the agent is independently deployable.
EXPO_PUBLIC_AI_API_URL=http://192.168.1.13:3000
EXPO_PUBLIC_SECRET_AI_KEY=d08e9274a3f330c6d8219d5a0378f4ab5ab78f1b0408e319d49a5dae301570e569e71a9acb7e0d150211cafe1668449aa7ac982ac03dfd8149275fbab7a5f9d6

# Google OAuth — used for Sign-in-with-Google on the merchant onboarding
# entry point. Client IDs are public by design.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
